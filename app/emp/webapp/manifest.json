{
  "_version": "1.58.0",
  "sap.app": {
    "id": "com.company.employeemanagement",
    "type": "application",
    "title": "Employee Management",
    "description": "Ứng dụng quản lý nhân viên SAP BTP",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/employee/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": false
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.company.employeemanagement.view.App",
      "type": "XML",
      "id": "appView"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.layout": {},
        "sap.ui.unified": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "com.company.employeemanagement.i18n.i18n" }
      },
      "appView": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": { "data": { "isAdmin": false, "userEmail": "" } }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.company.employeemanagement.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "transition": "slide"
      },
      "routes": [
        {
          "name": "EmployeeList",
          "pattern": "",
          "target": ["EmployeeList"]
        },
        {
          "name": "EmployeeDetail",
          "pattern": "employees/{employeeId}",
          "target": ["EmployeeDetail"]
        },
        {
          "name": "LeaveRequests",
          "pattern": "leaverequests",
          "target": ["LeaveRequests"]
        }
      ],
      "targets": {
        "EmployeeList":   { "viewName": "EmployeeList",   "viewId": "EmployeeList"   },
        "EmployeeDetail": { "viewName": "EmployeeDetail", "viewId": "EmployeeDetail" },
        "LeaveRequests":  { "viewName": "LeaveRequests",  "viewId": "LeaveRequests"  }
      }
    }
  }
}
